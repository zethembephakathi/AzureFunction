@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<div class="container mt-4">
    <!-- Welcome Message -->
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h2 class="fw-bold text-primary">Welcome to your Dashboard!</h2>
            <p class="text-muted">Here you can manage customers, products, orders, and more.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3 col-6">
            <a asp-controller="Customer" asp-action="Index" class="text-decoration-none">
                <div class="card pink-card text-center h-100">
                    <div class="card-body">
                        <div class="mb-2">
                            <i class="bi bi-people-fill" style="font-size:2rem;color:#ff1493;"></i>
                        </div>
                        <h5 class="card-title">Total Customers</h5>
                        <p class="display-6 fw-bold">@ViewBag.CustomerCount</p>
                        <span class="btn btn-outline-primary mt-2">Manage Customers</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-6">
            <a asp-controller="Product" asp-action="Index" class="text-decoration-none">
                <div class="card pink-card text-center h-100">
                    <div class="card-body">
                        <div class="mb-2">
                            <i class="bi bi-box-seam" style="font-size:2rem;color:#ff1493;"></i>
                        </div>
                        <h5 class="card-title">Total Products</h5>
                        <p class="display-6 fw-bold">@ViewBag.ProductCount</p>
                        <span class="btn btn-outline-primary mt-2">Manage Products</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-6">
            <a asp-controller="Order" asp-action="Index" class="text-decoration-none">
                <div class="card pink-card text-center h-100">
                    <div class="card-body">
                        <div class="mb-2">
                            <i class="bi bi-cart-check-fill" style="font-size:2rem;color:#ff1493;"></i>
                        </div>
                        <h5 class="card-title">Orders in Queue</h5>
                        <p class="display-6 fw-bold">@ViewBag.OrdersInQueue</p>
                        <span class="btn btn-outline-primary mt-2">Manage Orders</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-6">
            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">
                <div class="card pink-card text-center h-100">
                    <div class="card-body">
                        <div class="mb-2">
                            <i class="bi bi-cloud-arrow-up-fill" style="font-size:2rem;color:#ff1493;"></i>
                        </div>
                        <h5 class="card-title">Recent Uploads</h5>
                        <p class="display-6 fw-bold">@ViewBag.RecentUploads</p>
                        <span class="btn btn-outline-primary mt-2">View Uploads</span>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
