@model ABC_Retail.Models.Products
@{
    ViewData["Title"] = "Create Product";
}

<div class="card pink-card mb-4">
    <div class="card-body">
        <h2 class="card-title">Create Product</h2>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" /> <!-- optional if ID generated in controller -->

            <div class="mb-2">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Name" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-2">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" placeholder="Description" required />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-2">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Price" required />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-2">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" placeholder="Category" required />
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="mb-2">
                <label asp-for="StockQuantity" class="form-label"></label>
                <input asp-for="StockQuantity" type="number" class="form-control" placeholder="Stock Quantity" required />
                <span asp-validation-for="StockQuantity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Upload Image</label>
                <input type="file" name="ImageFile" accept="image/*" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-primary">Submit Product</button>
        </form>

        <a asp-action="Index" class="btn btn-link mt-2">Back to List</a>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
