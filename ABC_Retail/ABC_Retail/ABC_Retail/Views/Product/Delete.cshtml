@model ABC_Retail.Models.Products
@{
    ViewData["Title"] = "Delete Product";
}

<div class="card pink-card mb-4">
    <div class="card-body">
        <h2 class="card-title">Delete Product</h2>

        <h5 class="text-danger">Are you sure you want to delete this product?</h5>

        <table class="table table-bordered mt-3">
            <tr>
                <th>ID</th>
                <td>@Model.Id</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>@Model.Description</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>@Model.Price</td>
            </tr>
            <tr>
                <th>Category</th>
                <td>@Model.Category</td>
            </tr>
            <tr>
                <th>Stock Quantity</th>
                <td>@Model.StockQuantity</td>
            </tr>
            <tr>
                <th>Image</th>
                <td>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="Product Image" width="100" />
                    }
                </td>
            </tr>
        </table>

        <form asp-action="DeleteConfirmed" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>
